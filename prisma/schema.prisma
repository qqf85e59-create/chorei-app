generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  grade     String
  email     String?  @unique
  password  String
  role      String   @default("member")
  createdAt DateTime @default(now())
  speakerSessions     Session[]        @relation("SessionSpeaker")
  commentatorSessions Session[]        @relation("SessionCommentators")
  attendances       Attendance[]
  absenceRequests   AbsenceRequest[]
  commentatorViews  CommentatorView[]
  configHistories   ConfigHistory[]  @relation("ConfigHistoryChangedBy")
  notifications     Notification[]
}

model Phase {
  id                     Int      @id @default(autoincrement())
  phaseNumber            Int      @unique
  name                   String
  startDate              DateTime
  endDate                DateTime
  sessionDurationMinutes Int      @default(10)
  description            String?

  topics   Topic[]
  sessions Session[]
}

model Topic {
  id         Int      @id @default(autoincrement())
  phaseId    Int
  weekNumber Int
  topicText  String
  createdAt  DateTime @default(now())

  phase    Phase     @relation(fields: [phaseId], references: [id])
  sessions Session[]
}

model Session {
  id          Int       @id @default(autoincrement())
  date        DateTime
  phaseId     Int
  weekNumber  Int
  topicId     Int
  speakerId   String?
  startTime   String    @default("09:00")
  endTime     String    @default("09:10")
  status      String    @default("scheduled")
  adminNote   String?
  roundNumber Int       @default(1)
  commentatorsUpdatedAt DateTime?
  commentatorsPreset    Boolean   @default(false)

  phase            Phase             @relation(fields: [phaseId], references: [id])
  topic            Topic             @relation(fields: [topicId], references: [id])
  speaker          User?             @relation("SessionSpeaker", fields: [speakerId], references: [id])
  commentators     User[]            @relation("SessionCommentators")
  attendances      Attendance[]
  absenceRequests  AbsenceRequest[]
  commentatorViews CommentatorView[]
  notifications    Notification[]
}

model Attendance {
  id         Int       @id @default(autoincrement())
  sessionId  Int
  userId     String
  status     String    @default("present")
  reportedAt DateTime?
  adminNote  String?

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
}

model AbsenceRequest {
  id          Int      @id @default(autoincrement())
  userId      String
  sessionId   Int
  type        String
  requestedAt DateTime @default(now())
  note        String?
  originalSpeaker          Boolean  @default(false)
  previousAttendanceStatus String?

  user    User    @relation(fields: [userId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    String
  sessionId Int?
  type      String
  message   String
  createdAt DateTime  @default(now())
  readAt    DateTime?

  user    User     @relation(fields: [userId], references: [id])
  session Session? @relation(fields: [sessionId], references: [id])
}

model Holiday {
  id       Int      @id @default(autoincrement())
  date     DateTime @unique
  name     String
  isActive Boolean  @default(true)
}

model Config {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model ConfigHistory {
  id         Int      @id @default(autoincrement())
  configKey  String
  oldValue   String?
  newValue   String
  changedBy  String
  changedAt  DateTime @default(now())

  changedByUser User @relation("ConfigHistoryChangedBy", fields: [changedBy], references: [id])

  @@index([configKey, changedAt])
}

model CommentatorView {
  id        Int      @id @default(autoincrement())
  userId    String
  sessionId Int
  seenAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  @@unique([userId, sessionId])
}
