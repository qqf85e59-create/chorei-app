generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS（型安全・typo防止）
// grade / ScheduleResponse.response / SurveyResponse.budget は
// 記号や可変値を含むため文字列のまま据え置く。
// ============================================
enum Role {
  member
  admin
}

// choreiStatus / lunchStatus 共用（有効/無効）
enum ActivityStatus {
  active
  inactive
}

enum LunchRole {
  participant
  organizer
}

enum SessionStatus {
  scheduled
  completed
  cancelled
}

enum AttendanceStatus {
  present
  absent
  unspoken
  left_early
}

enum AbsenceType {
  absent
  unspoken
  leave_early
}

enum LunchEventStatus {
  planning
  scheduled
  completed
  cancelled
}

enum SettlementStatus {
  unpaid
  paid
}

model User {
  id        String   @id @default(cuid())
  name      String
  grade     String
  email     String?  @unique
  password  String
  role      Role     @default(member)
  lunchStatus ActivityStatus @default(active)
  choreiStatus ActivityStatus @default(active)
  createdAt DateTime @default(now())
  deletedAt DateTime?
  
  speakerSessions     Session[]        @relation("SessionSpeaker")
  commentatorSessions Session[]        @relation("SessionCommentators")
  attendances       Attendance[]
  absenceRequests   AbsenceRequest[]
  commentatorViews  CommentatorView[]
  configHistories   ConfigHistory[]  @relation("ConfigHistoryChangedBy")
  notifications     Notification[]

  @@index([deletedAt])

  // Lunch feature relations
  lunchRole      LunchRole @default(participant)
  employeeNumber String? @unique
  kana           String?
  jobCode        String?
  jobTitle       String?
  
  organizedLunches    LunchEvent[]        @relation("LunchOrganizer")
  lunchParticipations Participation[]
  scheduleResponses   ScheduleResponse[]
  surveyResponses     SurveyResponse[]
  favoriteRestaurants FavoriteRestaurant[]
  exclusionsMade      ExclusionLog[]      @relation("excludedBy")
  exclusionTarget     ExclusionLog[]      @relation("excludedUser")
  lunchComments       LunchComment[]

  @@index([lunchRole])
}

model Phase {
  id                     Int      @id @default(autoincrement())
  phaseNumber            Int      @unique
  name                   String
  startDate              DateTime
  endDate                DateTime
  sessionDurationMinutes Int      @default(10)
  description            String?

  topics   Topic[]
  sessions Session[]
}

model Topic {
  id         Int      @id @default(autoincrement())
  phaseId    Int
  weekNumber Int
  topicText  String
  createdAt  DateTime @default(now())

  phase    Phase     @relation(fields: [phaseId], references: [id])
  sessions Session[]
}

model Session {
  id          Int       @id @default(autoincrement())
  date        DateTime
  phaseId     Int
  weekNumber  Int
  topicId     Int
  speakerId   String?
  startTime   String    @default("09:00")
  endTime     String    @default("09:10")
  status      SessionStatus @default(scheduled)
  adminNote   String?
  roundNumber Int       @default(1)
  commentatorsUpdatedAt DateTime?
  commentatorsPreset    Boolean   @default(false)

  phase            Phase             @relation(fields: [phaseId], references: [id])
  topic            Topic             @relation(fields: [topicId], references: [id])
  speaker          User?             @relation("SessionSpeaker", fields: [speakerId], references: [id])
  commentators     User[]            @relation("SessionCommentators")
  attendances      Attendance[]
  absenceRequests  AbsenceRequest[]
  commentatorViews CommentatorView[]
  notifications    Notification[]

  @@index([phaseId])
  @@index([speakerId])
  @@index([date])
  @@index([phaseId, weekNumber])
}

model Attendance {
  id         Int       @id @default(autoincrement())
  sessionId  Int
  userId     String
  status     AttendanceStatus @default(present)
  reportedAt DateTime?
  adminNote  String?

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([userId])
}

model AbsenceRequest {
  id          Int      @id @default(autoincrement())
  userId      String
  sessionId   Int
  type        AbsenceType
  requestedAt DateTime @default(now())
  note        String?
  originalSpeaker          Boolean  @default(false)
  previousAttendanceStatus String?

  user    User    @relation(fields: [userId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([userId])
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    String
  sessionId Int?
  type      String
  message   String
  linkUrl   String?
  createdAt DateTime  @default(now())
  readAt    DateTime?

  user    User     @relation(fields: [userId], references: [id])
  session Session? @relation(fields: [sessionId], references: [id])

  @@index([userId, readAt])
}

model Holiday {
  id       Int      @id @default(autoincrement())
  date     DateTime @unique
  name     String
  isActive Boolean  @default(true)
}

model Config {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model ConfigHistory {
  id         Int      @id @default(autoincrement())
  configKey  String
  oldValue   String?
  newValue   String
  changedBy  String
  changedAt  DateTime @default(now())

  changedByUser User @relation("ConfigHistoryChangedBy", fields: [changedBy], references: [id])

  @@index([configKey, changedAt])
}

model CommentatorView {
  id        Int      @id @default(autoincrement())
  userId    String
  sessionId Int
  seenAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  @@unique([userId, sessionId])
  @@index([sessionId])
}

// ============================================
// LUNCH APP INTEGRATION MODELS
// ============================================

model LunchEvent {
  id              Int           @id @default(autoincrement())
  title           String        // 例："2026年6月ランチ会"
  organizerId     String
  organizer       User          @relation("LunchOrganizer", fields: [organizerId], references: [id])
  status          LunchEventStatus // planning | scheduled | completed | cancelled
  confirmedDate   DateTime?
  restaurantId    Int?
  restaurant      Restaurant?   @relation(fields: [restaurantId], references: [id])
  totalCost       Int?
  createdAt       DateTime      @default(now())
  
  participants    Participation[]
  scheduleCandidates ScheduleCandidate[]
  surveyResponses SurveyResponse[]
  exclusionLogs   ExclusionLog[]
  comments        LunchComment[]
  photos          LunchPhoto[]
  settlements     Settlement[]

  @@index([status])
  @@index([createdAt])
  @@index([organizerId])
  @@index([restaurantId])
}

model Participation {
  id          Int       @id @default(autoincrement())
  eventId     Int
  event       LunchEvent @relation(fields: [eventId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  isOrganizer Boolean   @default(false)
  attended    Boolean   @default(true)   // 実参加フラグ。false=当日欠席(no-show)。精算はattended=trueのみで割り勘。

  @@unique([eventId, userId])
  @@index([userId])
}

model ScheduleCandidate {
  id          Int       @id @default(autoincrement())
  eventId     Int
  event       LunchEvent @relation(fields: [eventId], references: [id])
  candidateDate DateTime
  note        String?
  responses   ScheduleResponse[]

  @@index([eventId])
}

model ScheduleResponse {
  id          Int       @id @default(autoincrement())
  candidateId Int
  candidate   ScheduleCandidate @relation(fields: [candidateId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  response    String    // "○" | "△" | "×"
  
  @@unique([candidateId, userId])
  @@index([userId])
}

model SurveyResponse {
  id          Int       @id @default(autoincrement())
  eventId     Int
  event       LunchEvent @relation(fields: [eventId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  genres      String    // JSON配列: ["和食","洋食"]
  area        String?
  budget      String?   // "〜1000" | "1000〜1500" | "1500〜2000" | "2000〜"
  
  @@unique([eventId, userId])
  @@index([userId])
}

model Restaurant {
  id          Int       @id @default(autoincrement())
  name        String
  genre       String
  area        String?
  address     String?
  phone       String?
  url         String?
  mapUrl      String?
  visitCount  Int       @default(0)
  lastVisited DateTime?
  createdAt   DateTime  @default(now())
  
  events      LunchEvent[]
  favorites   FavoriteRestaurant[]
}

model FavoriteRestaurant {
  id            Int       @id @default(autoincrement())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  restaurantId  Int
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id])
  comment       String?
  createdAt     DateTime  @default(now())
  
  @@unique([userId, restaurantId])
}

model ExclusionLog {
  id              Int       @id @default(autoincrement())
  eventId         Int
  event           LunchEvent @relation(fields: [eventId], references: [id])
  excludedUserId  String
  excludedUser    User      @relation("excludedUser", fields: [excludedUserId], references: [id])
  excludedById    String
  excludedBy      User      @relation("excludedBy", fields: [excludedById], references: [id])
  reason          String?
  createdAt       DateTime  @default(now())

  @@index([eventId])
}

model Settlement {
  id          Int       @id @default(autoincrement())
  eventId     Int
  event       LunchEvent @relation(fields: [eventId], references: [id])
  payerId     String
  totalAmount Int
  perPerson   Int
  status      SettlementStatus // unpaid | paid
  note        String?
  createdAt   DateTime  @default(now())

  @@index([eventId])
}

model LunchComment {
  id        Int       @id @default(autoincrement())
  eventId   Int
  event     LunchEvent @relation(fields: [eventId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime  @default(now())

  @@index([eventId])
  @@index([createdAt])
}

model LunchPhoto {
  id        Int       @id @default(autoincrement())
  eventId   Int
  event     LunchEvent @relation(fields: [eventId], references: [id])
  url       String
  caption   String?
  createdAt DateTime  @default(now())

  @@index([eventId])
}
